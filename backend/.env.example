PORT=5000
MONGO_URI=mongodb://localhost:27017/agrifather
OPENROUTER_API_KEY=your_openrouter_api_key
JWT_SECRET=agrifather_super_secret_key_123

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ==============================================================================
# SMTP Config (OTP Emails)
# ==============================================================================
# By default, SMTP_HOST is smtp.gmail.com and SMTP_PORT is 587.
# Fill SMTP_EMAIL and SMTP_PASSWORD to enable email OTP.

# Option 1: Standard Gmail SMTP Configuration
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Option 2: Brevo (Formerly Sendinblue) Configuration (Free, 300 emails/day)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_EMAIL=your_brevo_registered_email@example.com
# SMTP_PASSWORD=your_brevo_smtp_key_starts_with_xkeysib

# Option 3: Resend Configuration (Free, 100 emails/day, requires custom domain)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_EMAIL=resend
# SMTP_PASSWORD=your_resend_api_key_starts_with_re_
# SMTP_FROM_EMAIL=otp@agrifather.com
